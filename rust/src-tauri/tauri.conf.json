{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Edge TTS GUI Rust",
  "version": "0.1.0",
  "identifier": "com.edge.tts.gui.rust",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "文本转语音",
        "width": 740,
        "height": 580,
        "minWidth": 740,
        "minHeight": 580,
        "maxWidth": 740,
        "maxHeight": 580,
        "maximizable": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "targets": [],
    "icon": ["icons/icon.ico"]
  }
}
